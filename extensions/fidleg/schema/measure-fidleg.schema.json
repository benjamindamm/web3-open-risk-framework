{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Web3 Measure Entry with FIDLEG Extension",
  "allOf": [
    {
      "$ref": "../../schema/measure.schema.json"
    },
    {
      "properties": {
        "regulatoryExtensions": {
          "type": "object",
          "description": "Modular regulatory extensions for different jurisdictions",
          "properties": {
            "fidleg": {
              "type": "object",
              "description": "Swiss FIDLEG regulatory extension for DeFi protocol assessment",
              "properties": {
                "articleReference": {
                  "type": "string",
                  "enum": [
                    "FIDLEG_Art72",
                    "FIDLEG_Art142"
                  ],
                  "description": "Core FIDLEG articles for DeFi protocol assessment: Art. 72 (Operational Risks), Art. 142 (Market Abuse)"
                },
                "implementationDeadline": {
                  "type": "string",
                  "format": "date",
                  "description": "Deadline for implementing this measure"
                },
                "auditFrequency": {
                  "type": "string",
                  "enum": [
                    "QUARTERLY",
                    "ANNUAL"
                  ],
                  "description": "Required audit frequency for this measure"
                },
                "regulatoryRequirement": {
                  "type": "string",
                  "enum": [
                    "MANDATORY",
                    "RECOMMENDED",
                    "OPTIONAL"
                  ],
                  "description": "Regulatory requirement level for banks"
                }
              },
              "required": [
                "articleReference",
                "regulatoryRequirement"
              ],
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  ]
}