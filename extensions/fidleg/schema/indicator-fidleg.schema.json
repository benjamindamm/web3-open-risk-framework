{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Web3 Indicator Entry with FIDLEG Extension",
  "allOf": [
    { "$ref": "../../schema/indicator.schema.json" },
    {
      "properties": {
        "regulatoryExtensions": {
          "type": "object",
          "description": "Modular regulatory extensions for different jurisdictions",
          "properties": {
            "fidleg": {
              "type": "object",
              "description": "Swiss FIDLEG regulatory extension",
              "properties": {
                "articleReference": {
                  "type": "string",
                  "enum": [
                    "FIDLEG_Art24",
                    "FIDLEG_Art72",
                    "FIDLEG_Art142",
                    "FIDLEG_Art18_20",
                    "FIDLEG_Art8_10",
                    "FIDLEG_Art11_15",
                    "FIDLEG_Art16_18",
                    "FIDLEG_Art19_21",
                    "FIDLEG_Art22_24",
                    "FIDLEG_Art25_30",
                    "FIDLEG_Art31_35",
                    "FIDLEG_Art36_40",
                    "FIDLEG_Art41_45",
                    "FIDLEG_Art46_50"
                  ],
                  "description": "FIDLEG article reference"
                },
                "measurementFrequency": {
                  "type": "string",
                  "enum": ["REAL_TIME", "DAILY", "WEEKLY", "MONTHLY", "QUARTERLY", "ANNUAL"],
                  "description": "Required measurement frequency for Swiss regulatory reporting"
                },
                "regulatoryThreshold": {
                  "type": "string",
                  "description": "Compliance threshold for Swiss regulatory reporting"
                },
                "auditRequirement": {
                  "type": "string",
                  "enum": ["INTERNAL_AUDIT", "EXTERNAL_AUDIT", "REGULATORY_AUDIT", "NO_AUDIT"],
                  "description": "Required audit level for Swiss compliance"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": {
            "type": "object",
            "description": "Additional regulatory extensions for other jurisdictions"
          }
        }
      }
    }
  ]
}
