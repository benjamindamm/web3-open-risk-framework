{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Web3 Indicator Entry with FIDLEG Extension",
  "allOf": [
    {
      "$ref": "../../schema/indicator.schema.json"
    },
    {
      "properties": {
        "regulatoryExtensions": {
          "type": "object",
          "description": "Modular regulatory extensions for different jurisdictions",
          "properties": {
            "fidleg": {
              "type": "object",
              "description": "Swiss FIDLEG regulatory extension for DeFi protocol assessment",
              "properties": {
                "articleReference": {
                  "type": "string",
                  "enum": [
                    "FIDLEG_Art72",
                    "FIDLEG_Art142"
                  ],
                  "description": "Core FIDLEG articles for DeFi protocol assessment: Art. 72 (Operational Risks), Art. 142 (Market Abuse)"
                },
                "indicatorType": {
                  "type": "string",
                  "enum": [
                    "PROTOCOL_SECURITY",
                    "MARKET_ABUSE"
                  ],
                  "description": "Protocol assessment types: PROTOCOL_SECURITY (Art. 72), MARKET_ABUSE (Art. 142)"
                },
                "measurementFrequency": {
                  "type": "string",
                  "enum": [
                    "REAL_TIME",
                    "DAILY",
                    "WEEKLY",
                    "MONTHLY"
                  ],
                  "description": "Required measurement frequency for protocol monitoring"
                },
                "riskLevel": {
                  "type": "string",
                  "enum": [
                    "LOW",
                    "MEDIUM",
                    "HIGH",
                    "CRITICAL"
                  ],
                  "description": "Protocol risk level for bank assessment"
                },
                "suspiciousPatterns": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "mev_arbitrage",
                      "wash_trading",
                      "flash_loan_exploitation",
                      "governance_manipulation",
                      "structuring",
                      "unhosted_wallet"
                    ]
                  },
                  "description": "Key suspicious patterns for DeFi protocol assessment"
                },
                "auditRequirement": {
                  "type": "object",
                  "description": "Audit requirements for protocol compliance",
                  "properties": {
                    "level": {
                      "type": "string",
                      "enum": [
                        "INTERNAL",
                        "EXTERNAL",
                        "REGULATORY"
                      ]
                    },
                    "frequency": {
                      "type": "string",
                      "enum": [
                        "QUARTERLY",
                        "ANNUAL"
                      ]
                    }
                  },
                  "required": [
                    "level",
                    "frequency"
                  ]
                }
              },
              "required": [
                "articleReference",
                "indicatorType",
                "riskLevel"
              ],
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  ]
}