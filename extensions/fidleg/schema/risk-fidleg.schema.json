{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Web3 Risk Entry with FIDLEG Extension",
  "allOf": [
    { "$ref": "../../schema/risk.schema.json" },
    {
      "properties": {
        "regulatoryExtensions": {
          "type": "object",
          "description": "Modular regulatory extensions for different jurisdictions",
          "properties": {
            "fidleg": {
              "type": "object",
              "description": "Swiss FIDLEG regulatory extension",
              "properties": {
                "articleReference": {
                  "type": "string",
                  "enum": [
                    "FIDLEG_Art24",
                    "FIDLEG_Art72",
                    "FIDLEG_Art142",
                    "FIDLEG_Art18_20",
                    "FIDLEG_Art8_10",
                    "FIDLEG_Art11_15",
                    "FIDLEG_Art16_18",
                    "FIDLEG_Art19_21",
                    "FIDLEG_Art22_24",
                    "FIDLEG_Art25_30",
                    "FIDLEG_Art31_35",
                    "FIDLEG_Art36_40",
                    "FIDLEG_Art41_45",
                    "FIDLEG_Art46_50"
                  ],
                  "description": "FIDLEG article reference. See article-reference.md for detailed article descriptions."
                },
                "regulatoryClassification": {
                  "type": "string",
                  "enum": [
                    "CUSTOMER_PROTECTION",
                    "RISK_MANAGEMENT",
                    "MARKET_INTEGRITY",
                    "CLIENT_PROTECTION",
                    "ORGANIZATIONAL",
                    "CONDUCT",
                    "PRODUCT_MANAGEMENT",
                    "COMPLIANCE",
                    "CLIENT_SERVICES",
                    "INVESTMENT_SERVICES",
                    "ORDER_EXECUTION",
                    "ASSET_PROTECTION",
                    "REPORTING"
                  ],
                  "description": "Swiss regulatory classification. See fidleg-fields-guide.md for classification definitions."
                },
                "complianceRequirement": {
                  "type": "object",
                  "description": "Swiss compliance requirement details",
                  "properties": {
                    "level": {
                      "type": "string",
                      "enum": ["MANDATORY", "RECOMMENDED", "OPTIONAL"],
                      "description": "Compliance requirement level. See compliance-requirement.md for level definitions."
                    },
                    "documentation": {
                      "type": "object",
                      "description": "Documentation requirements",
                      "properties": {
                        "frequency": {
                          "type": "string",
                          "enum": ["quarterly", "annual", "monthly", "on_demand"],
                          "description": "Required documentation frequency. See compliance-requirement.md for frequency definitions."
                        }
                      },
                      "required": ["frequency"]
                    }
                  },
                  "required": ["level"]
                },
                "riskLevel": {
                  "type": "string",
                  "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"],
                  "description": "Swiss risk level classification. See risk-level.md for risk level definitions."
                },
                "applicability": {
                  "type": "object",
                  "description": "Risk applicability for different customer types",
                  "properties": {
                    "customerType": {
                      "type": "string",
                      "enum": ["retail", "professional", "both"],
                      "description": "Applicable customer type. See customer-type.md for customer type definitions."
                    }
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": {
            "type": "object",
            "description": "Additional regulatory extensions for other jurisdictions"
          }
        }
      }
    }
  ]
}
