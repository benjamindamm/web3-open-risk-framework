{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Web3 Risk Entry with FIDLEG Extension",
  "allOf": [
    {
      "$ref": "../../../schema/risk.schema.json"
    },
    {
      "properties": {
        "regulatoryExtensions": {
          "type": "object",
          "description": "Modular regulatory extensions for different jurisdictions",
          "properties": {
            "fidleg": {
              "type": "object",
              "description": "Swiss FIDLEG regulatory extension for DeFi protocol assessment",
              "properties": {
                "articleReference": {
                  "type": "string",
                  "enum": [
                    "FIDLEG_Art72",
                    "FIDLEG_Art142"
                  ],
                  "description": "Core FIDLEG articles for DeFi protocol assessment: Art. 72 (Operational Risks), Art. 142 (Market Abuse)"
                },
                "regulatoryClassification": {
                  "type": "string",
                  "enum": [
                    "OPERATIONAL_RISK",
                    "MARKET_RISK",
                    "COMPLIANCE_RISK"
                  ],
                  "description": "Regulatory risk classification for protocol assessment"
                },
                "complianceRequirement": {
                  "type": "string",
                  "enum": [
                    "MANDATORY",
                    "RECOMMENDED",
                    "OPTIONAL"
                  ],
                  "description": "Compliance requirement level for banks"
                },
                "riskLevel": {
                  "type": "string",
                  "enum": [
                    "LOW",
                    "MEDIUM",
                    "HIGH",
                    "CRITICAL"
                  ],
                  "description": "Protocol risk level for bank assessment"
                }
              },
              "required": [
                "articleReference",
                "regulatoryClassification",
                "riskLevel"
              ],
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  ]
}